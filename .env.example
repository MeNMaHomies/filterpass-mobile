# iOS simulator / web (backend on same machine)
EXPO_PUBLIC_API_URL=http://localhost:8000

# Android emulator: localhost is rewritten to 10.0.2.2 at runtime.
# You can also set it explicitly:
#   EXPO_PUBLIC_API_URL=http://10.0.2.2:8000
# Optional adb reverse (alternative to 10.0.2.2):
#   npm run adb-reverse

# Physical phone — backend must listen on 0.0.0.0:8000 (not only 127.0.0.1):
#   EXPO_PUBLIC_API_URL=http://192.168.1.102:8000
