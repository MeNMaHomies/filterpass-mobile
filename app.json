{
	"expo": {
		"name": "filterpass-mobile",
		"slug": "filterpass-mobile",
		"version": "1.0.0",
		"orientation": "portrait",
		"icon": "./assets/images/icon.png",
		"scheme": "filterpassmobile",
		"userInterfaceStyle": "dark",
		"ios": {
			"icon": "./assets/expo.icon",
			"infoPlist": {
				"NSMicrophoneUsageDescription": "FilterPass needs microphone access for live spoof detection."
			}
		},
		"android": {
			"package": "com.filterpass.mobile",
			"adaptiveIcon": {
				"backgroundColor": "#E6F4FE",
				"foregroundImage": "./assets/images/android-icon-foreground.png",
				"backgroundImage": "./assets/images/android-icon-background.png",
				"monochromeImage": "./assets/images/android-icon-monochrome.png"
			},
			"permissions": [
				"android.permission.RECORD_AUDIO",
				"android.permission.MODIFY_AUDIO_SETTINGS"
			],
			"predictiveBackGestureEnabled": false
		},
		"web": {
			"output": "static",
			"favicon": "./assets/images/favicon.png"
		},
		"plugins": [
			"expo-router",
			[
				"expo-font",
				{
					"fonts": [
						"node_modules/@expo-google-fonts/geist/400Regular/Geist_400Regular.ttf",
						"node_modules/@expo-google-fonts/geist/500Medium/Geist_500Medium.ttf",
						"node_modules/@expo-google-fonts/geist/600SemiBold/Geist_600SemiBold.ttf",
						"node_modules/@expo-google-fonts/geist/700Bold/Geist_700Bold.ttf",
						"node_modules/@expo-google-fonts/geist-mono/400Regular/GeistMono_400Regular.ttf",
						"node_modules/@expo-google-fonts/geist-mono/500Medium/GeistMono_500Medium.ttf",
						"node_modules/@expo-google-fonts/geist-mono/600SemiBold/GeistMono_600SemiBold.ttf"
					]
				}
			],
			[
				"expo-splash-screen",
				{
					"backgroundColor": "#0A0A0C",
					"image": "./assets/images/splash-icon.png",
					"imageWidth": 76
				}
			],
			"expo-audio",
			"expo-dev-client",
			"./modules/filterpass-call-capture/app.plugin.js"
		],
		"experiments": {
			"typedRoutes": true,
			"reactCompiler": true
		},
		"extra": {
			"router": {},
			"eas": {
				"projectId": "bf8c669f-dfb3-4224-9180-4d51f91efc3a"
			}
		},
		"owner": "jlords32s-team"
	}
}
