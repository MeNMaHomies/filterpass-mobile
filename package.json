	"scripts": {
		"start": "expo start",
		"reset-project": "node ./scripts/reset-project.js",
		"adb-reverse": "adb reverse tcp:8000 tcp:8000",
		"android": "adb reverse tcp:8000 tcp:8000 && expo start --android",
		"android:prebuild": "npx expo prebuild --platform android",
		"android:run": "adb reverse tcp:8000 tcp:8000 && npx expo run:android",
		"android:apk": "cd android && ./gradlew assembleDebug",
		"ios": "expo start --ios",
		"web": "expo start --web",
		"lint": "expo lint",
		"typecheck": "tsc --noEmit",
		"build": "expo export --platform web",
		"format": "prettier --write \"src/**/*.{ts,tsx,js,jsx}\" \"*.{js,ts,json,md}\" \"docs/**/*.md\"",
		"format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx}\" \"*.{js,ts,json,md}\" \"docs/**/*.md\"",
		"test": "jest",
		"test:watch": "jest --watchAll"
	},
	"private": true
