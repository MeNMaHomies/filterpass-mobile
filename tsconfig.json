{
	"extends": "expo/tsconfig.base",
	"compilerOptions": {
		"strict": true,
		"paths": {
			"@/*": ["./src/*"],
			"@/assets/*": ["./assets/*"],
			"moti/view": ["./node_modules/moti/build/components/view"],
			"moti/core": ["./node_modules/moti/build/core/index"]
		}
	},
	"include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"],
	"exclude": [
		"node_modules",
		"**/__tests__/**",
		"**/*.test.ts",
		"**/*.test.tsx"
	]
}
